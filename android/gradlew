##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh does
#       not find it on the first line, but has some other value, this may cause
#       problems.
#
#   (2) The slurped sed <<EOF constructs will not work with leading whitespace
#       without modification of IFS and using echo instead of print in some
#       implementations.
#
#   (3) This script is generated from the Groovy template
#       https://github.com/gradle/gradle/blob/master/subprojects/plugins/src/main/resources/org/gradle/api/internal/plugins/unixStartScript.txt
#       within the Gradle source tree
#
#   You can find Gradle at https://gradle.org
#
##############################################################################

# Attempt to set APP_HOME

# Resolve links: $0 may be a symlink
app_path=$0

# Need this for daisy-chained symlinks.
while
    APP_HOME=${app_path%"${app_path##*/}"}
    [ -n "$APP_HOME" ] &&
    app_path=$APP_HOME/$(readlink "$app_path")
do
    :
done

APP_HOME=$(cd "${APP_HOME:-.}" && pwd -P) || exit

appname="${0##*/}"
exec "${JAVA_HOME}/bin/java" -Xmx4096M -Xms1024M "-Dorg.gradle.appname=$appname" "-Dorg.gradle.jvmargs=-Xmx4096M -Xms1024M" -classpath "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" org.gradle.wrapper.GradleWrapperMain "$@"
